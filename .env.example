# Copy to ".env" and fill in. Vite only exposes vars prefixed with VITE_.

# Required: OAuth 2.0 Web client ID from Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Optional: pin everyone to one team file id. If you leave this blank, the app
# lets the first person create a team board and others join by pasting its
# share link. (You can copy the id from the share link: .../d/<THIS_PART>/view)
VITE_TEAM_FILE_ID=
